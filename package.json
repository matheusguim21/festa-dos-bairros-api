{
  "name": "festa-dos-bairros-api",
  "version": "1.2.0",
  "description": "Sistema de gerenciamento de estoque e venda da festas dos bairros d Igreja Verbo da Vida Retiro",
  "author": "matheusguim21",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build && bunx tsc-alias -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "bun run --bun dist/src/main.js",
    "dev": "bun run --bun --watch src/main.ts",
    "dev:bun": "bun run --bun --watch src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:bun": "bun run --bun dist/src/main.js",
    "build:start:bun": "pnpm run build && bun run --bun dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:seed:bun": "bun run prisma/seed.ts",
    "prisma:clear": "ts-node prisma/clear.ts",
    "prisma:clear:bun": "bun run prisma/clear.ts",
    "postinstall": "bunx --bun prisma generate",
    "prisma:generate": "bunx --bun prisma generate"
  },
  "dependencies": {
    "@fastify/multipart": "8.3.0",
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-fastify": "10.4.22",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@webundsoehne/nest-fastify-file-upload": "2.2.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "fastify": "4.28.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "write-excel-file": "^2.3.10",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.5.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/config": "^3.3.0",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.22",
    "@rocketseat/eslint-config": "^2.2.2",
    "@swc/core": "^1.15.33",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.41",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^2.1.9",
    "bun-types": "^1.3.13",
    "eslint": "^9.39.4",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "packageManager": "pnpm@10.7.0+sha512.6b865ad4b62a1d9842b61d674a393903b871d9244954f652b8842c2b553c72176b278f64c463e52d40fff8aba385c235c8c9ecf5cc7de4fd78b8bb6d49633ab6"
}
